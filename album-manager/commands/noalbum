#!/usr/bin/env bash
#
# Make every .flac file in a folder "albumless". Basically I don't want the
# albums of these songs to show up in the album lists given I don't have the
# entire album. Putting them in a big ass wrapper album called "noalbum".
#
# All these songs will be available in a playlist.
#
# Navidrome computes an album's identity from a bunch of shit so "noalbum" will
# show up a lot during searches:
# https://www.navidrome.org/docs/usage/library/tagging/
#
# Usage:
#   am noalbum <folder>
#
# <folder> is a path to a folder containing .flac files.

set -euo pipefail

ALBUM_NAME="~noalbum"

if [[ $# -ne 1 ]]; then
    echo "usage: am noalbum <folder>" >&2
    exit 2
fi

album=$1

if [[ ! -d $album ]]; then
    echo "error: not a directory: $album" >&2
    exit 1
fi

shopt -s nullglob nocaseglob
songs=("$album"/*.flac "$album"/*.mp3)
shopt -u nullglob nocaseglob

if [[ ${#songs[@]} -eq 0 ]]; then
    echo "error: no .flac or .mp3 files found in: $album" >&2
    exit 1
fi

flac_album() {
    metaflac --show-tag=ALBUM "$1" | head -n1 | cut -d= -f2-
}

mp3_album() {
    mid3v2 -l "$1" 2>/dev/null | sed -n 's/^TALB=//p' | head -n1
}

for f in "${songs[@]}"; do
    echo "===== ${f##*/} ====="

    ext=${f##*.}
    case ${ext,,} in
        flac) old_album=$(flac_album "$f") ;;
        mp3)  old_album=$(mp3_album "$f") ;;
    esac

    [[ $old_album != "$ALBUM_NAME" ]] && printf '  %-8s %s → %s\n' "ALBUM:" "${old_album:-(none)}" "$ALBUM_NAME"

    case ${ext,,} in
        # metaflac --set-tag appends, so remove first to avoid duplicate ALBUM tags.
        flac) metaflac --remove-tag=ALBUM --set-tag=ALBUM="$ALBUM_NAME" "$f" ;;
        mp3)  mid3v2 --TALB "$ALBUM_NAME" "$f" >/dev/null ;;
    esac
done

echo
echo "done: ${#songs[@]} file(s) set to album '$ALBUM_NAME'"
