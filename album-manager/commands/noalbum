#!/usr/bin/env bash
#
# Make every .flac file in a folder "albumless". Basically I don't want the
# albums of these songs to show up in the album lists given I don't have the
# entire album. Putting them in a big ass wrapper album called "noalbum".
#
# All these songs will be available in a playlist.
#
# Navidrome computes an album's identity from a bunch of shit so "noalbum" will
# show up a lot during searches:
# https://www.navidrome.org/docs/usage/library/tagging/
#
# Usage:
#   am noalbum <folder>
#
# <folder> is a path to a folder containing .flac files.

set -euo pipefail

ALBUM_NAME="~noalbum"

if [[ $# -ne 1 ]]; then
    echo "usage: am noalbum <folder>" >&2
    exit 2
fi

album=$1

if [[ ! -d $album ]]; then
    echo "error: not a directory: $album" >&2
    exit 1
fi

# https://www.gnu.org/software/bash/manual/html_node/The-Shopt-Builtin.html
shopt -s nullglob
flacs=("$album"/*.flac)
shopt -u nullglob

if [[ ${#flacs[@]} -eq 0 ]]; then
    echo "error: no .flac files found in: $album" >&2
    exit 1
fi

# Read the first value of a Vorbis comment tag, empty if the tag is absent.
tag_value() {
    metaflac --show-tag="$1" "$2" | head -n1 | cut -d= -f2-
}

for f in "${flacs[@]}"; do
    echo "===== ${f##*/} ====="

    # Show before -> after only when the album actually changes.
    old_album=$(tag_value ALBUM "$f")
    [[ $old_album != "$ALBUM_NAME" ]] && printf '  %-8s %s → %s\n' "ALBUM:" "${old_album:-(none)}" "$ALBUM_NAME"

    # Remove before set so we don't end up with duplicate ALBUM tags.
    metaflac --remove-tag=ALBUM --set-tag=ALBUM="$ALBUM_NAME" "$f"
done

echo
echo "done: ${#flacs[@]} file(s) set to album '$ALBUM_NAME'"
